# Copy to .env. Defaults target the Docker Compose stack (service hostnames).
# For a native local stack, override host/port to 127.0.0.1 and your ports.
REDIS_HOST=redis
REDIS_PORT=6379

POSTGRES_HOST=postgres
POSTGRES_PORT=5432
POSTGRES_DB=genai
POSTGRES_USER=genai
POSTGRES_PASSWORD=genai

SERVICE_NAME=genai-ai-service-layer
SERVICE_VERSION=1.0.0
